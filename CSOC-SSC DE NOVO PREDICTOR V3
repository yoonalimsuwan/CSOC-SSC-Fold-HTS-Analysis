# SECTION 6: THE PIPELINE
# ============================================================================

class AdvancedDeNovoPredictor:
    def __init__(self, config: CSOCAdvancedConfig):
        self.config = config
        self.device = torch.device(f'cuda:{config.device_id}' if torch.cuda.is_available() else 'cpu')
        
        self.aa2int = {aa: i for i, aa in enumerate('ACDEFGHIKLMNPQRSTVWY-')}
        self.prior_net = StructurePriorNet(embed_dim=config.embed_dim).to(self.device)
        self.prior_net.eval()
        
        self.builder = TorsionToCartesian().to(self.device)
        self.loss_engine = PhysicsLossEngine(config, self.device)
        self.asm_driver = FastASM(config.asm_L)
        
    def predict(self, seq: str):
        print(f"\n🧬 Initiating Torsion-Aware Prediction | Length: {len(seq)} AA")
        tokens = torch.tensor([self.aa2int.get(aa, 20) for aa in seq], device=self.device)
        
        # ML Prior
        with torch.no_grad():
            pred_distogram = self.prior_net(tokens)
            
        # Initialize internal coordinates (dihedrals) instead of XYZ
        # Start in extended beta-strand conformation
        dihedrals = torch.zeros((len(seq), 3), device=self.device, requires_grad=True)
        dihedrals.data[:, 0] = -2.35 # phi
        dihedrals.data[:, 1] = 2.35  # psi
        dihedrals.data[:, 2] = 3.14  # omega (trans)
        
        optimizer = LangevinTorsionOptimizer([dihedrals], lr=self.config.learning_rate)
        
        for recycle in range(self.config.n_recycling):
            print(f"\n🔄 Recycling Stage {recycle + 1}/{self.config.n_recycling}")
            
            for stage in range(self.config.n_stages):
                for i in range(self.config.n_iter_per_stage):
                    
                    A = self.asm_driver.step()
                    T = self.config.base_langevin_temp * (1.0 + 0.1 * math.log1p(A)) * (1 - stage/self.config.n_stages)
                    
                    optimizer.zero_grad()
                    
                    # Forward kinematics: Angles -> 3D Coordinates
                    coords3d = self.builder(dihedrals)
                    
                    # Compute Energy/Loss
                    loss, metrics = self.loss_engine.compute(coords3d, dihedrals, pred_distogram)
                    loss.backward()
                    
                    # Step with ASM-driven noise
                    torch.nn.utils.clip_grad_norm_([dihedrals], 1.0)
                    optimizer.step_with_noise(T)
                    
                    if i % 50 == 0:
                        print(f"   Iter {i:3d} | Total: {metrics['total']:7.2f} | "
                              f"Rama: {metrics['rama']:5.2f} | Clash: {metrics['clash']:5.2f} | T: {T:5.1f}K | A: {A:3d}")
                        
        # Finalization
        final_coords = self.builder(dihedrals).detach().cpu().numpy()
        print("\n✅ Prediction Complete. Backbone Built.")
        return final_coords

